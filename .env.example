# ===== B站账号 Cookie（登录后从浏览器 DevTools 获取）=====
# 未登录也可运行，但接口频率限制更严格
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_BUVID3=

# ===== LLM（OpenAI-compatible）=====
# 默认模型配置。Miner / Researcher 会优先读取各自的专属覆盖配置；
# 若未配置，则自动回退到这里。
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
# auto / openai / deepseek / moonshotai
LLM_PROVIDER=auto

# Miner 专属模型（可选，不填则继承 LLM_*）
MINER_LLM_API_KEY=
MINER_LLM_BASE_URL=
MINER_LLM_MODEL=
MINER_LLM_PROVIDER=

# Researcher 专属模型（可选，不填则继承 LLM_*）
RESEARCH_LLM_API_KEY=
RESEARCH_LLM_BASE_URL=
RESEARCH_LLM_MODEL=
RESEARCH_LLM_PROVIDER=

# ===== Web 搜索（火山引擎联网搜索）=====
# 开通：https://console.volcengine.com/search-infinity/web-search
# API Key：https://console.volcengine.com/search-infinity/api-key
WEB_SEARCH_API_KEY=

# ===== BibiGPT（B站视频内容总结）=====
BIBIGPT_API_TOKEN=
BIBIGPT_BASE_URL=https://api.bibigpt.co/api
BIBIGPT_MAX_DURATION_SECONDS=900

# ===== Meilisearch =====
# 至少 16 字节，生产环境建议用随机字符串
# 生成命令：openssl rand -base64 24
# 本地开发（app 在宿主机运行）：http://localhost:7700
# 生产部署（app 在 Docker 内运行）：http://meilisearch:7700
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=dev-master-key-1234

# ===== 采集参数 =====
SCOUT_TOP_N_VIDEOS=5
SCOUT_COMMENTS_PER_VIDEO=5
SCOUT_SCORE_THRESHOLD=5.0
SCOUT_NEW_WORD_MIN_DOCS=3
# 请求延迟范围（秒）
SCOUT_DELAY_MIN=0.8
SCOUT_DELAY_MAX=2.5
# 可选代理（格式: http://user:pass@host:port）
SCOUT_PROXY_URL=

# ===== AI 分析参数 =====
AI_BATCH_SIZE=50
AI_CONFIDENCE_THRESHOLD=0.65
RESEARCH_SCREEN_TIMEOUT_SECONDS=60
RESEARCH_SCREEN_MAX_RETRIES=1
RESEARCH_LLM_TIMEOUT_SECONDS=120
RESEARCH_LLM_MAX_RETRIES=1
MINER_COMMENT_CONFIDENCE_THRESHOLD=0.60
MINER_COMMENTS_BATCH_SIZE=8
MINER_LLM_TIMEOUT_SECONDS=90
MINER_LLM_MAX_RETRIES=1

# ===== 数据路径 =====
DUCKDB_PATH=data/duckdb/freq.db
USERDICT_PATH=data/dicts/userdict.txt
MEDIA_ASSET_ROOT=data/assets

# ===== 日志 =====
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_JSON_FILENAME=app.jsonl
