# ===== B站账号 Cookie（登录后从浏览器 DevTools 获取）=====
# 未登录也可运行，但接口频率限制更严格
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_BUVID3=

# ===== LLM =====
DEEPSEEK_API_KEY=sk-your-key-here
# DeepSeek 使用 OpenAI 兼容接口，无需修改
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== Web 搜索（Serper，有免费额度）=====
# 注册地址：https://serper.dev
SERPER_API_KEY=

# ===== Meilisearch =====
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=dev-master-key

# ===== 采集参数 =====
SCOUT_TOP_N_VIDEOS=20
SCOUT_COMMENTS_PER_VIDEO=500
SCOUT_SCORE_THRESHOLD=5.0
SCOUT_NEW_WORD_MIN_DOCS=3
# 请求延迟范围（秒）
SCOUT_DELAY_MIN=0.8
SCOUT_DELAY_MAX=2.5
# 可选代理（格式: http://user:pass@host:port）
SCOUT_PROXY_URL=

# ===== AI 分析参数 =====
AI_BATCH_SIZE=50
AI_CONFIDENCE_THRESHOLD=0.65

# ===== 数据路径 =====
DUCKDB_PATH=data/duckdb/freq.db
USERDICT_PATH=data/dicts/userdict.txt
